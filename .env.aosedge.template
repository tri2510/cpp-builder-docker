# AosEdge Build & Deploy Pipeline Configuration
# Copy this file to .env and fill in your values

# ============================================
# Build Configuration
# ============================================
# Target architecture: amd64, arm64, armhf
TARGET=amd64

# ============================================
# Azure Key Vault Configuration
# ============================================
# Azure Key Vault URL
VAULT_URL=https://your-vault.vault.azure.net

# Certificate name in Key Vault
CERT_NAME=your-certificate-name

# Use Managed Identity (true for Azure Functions, false for local/dev)
USE_MANAGED_ID=false

# Client Credentials (only if not using Managed Identity)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ============================================
# AosEdge API Configuration
# ============================================
# AosEdge API URL
AOS_API_URL=https://aoscloud.io:10000/api/v10

# Unit ID to deploy to
UNIT_ID=aos-unit-001

# Subject ID (optional - will create if not specified)
SUBJECT_ID=

# Service ID
SERVICE_ID=aos-agent

# API Key for authentication (optional)
AOS_API_KEY=
